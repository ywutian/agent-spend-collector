# Read-only provider credentials. Prefer restricted/read-only keys.

# Anthropic Admin Usage/Cost API key.
ANTHROPIC_ADMIN_KEY=sk-ant-admin01-...

# OpenRouter API key. Used by the gateway proxy and optional generation metadata pulls.
OPENROUTER_API_KEY=sk-or-...

# AWS read-only Cost Explorer credentials.
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_SESSION_TOKEN=

# Stripe restricted key with read access to Events and PaymentIntents.
STRIPE_SECRET_KEY=rk_live_...

# Merchant receiving address for x402/Base USDC settlements.
X402_PAY_TO=0xYourReceivingAddress

# Receiving address for direct Base USDC transfers.
USDC_PAY_TO=0xYourReceivingAddress

# Optional JSON file mapping budget_id -> cap in reporting currency.
SPEND_BUDGETS_FILE=budgets.example.json

# Optional network tuning for live pulls.
SPEND_HTTP_TIMEOUT=30
SPEND_HTTP_RETRIES=3
