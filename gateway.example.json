{
  "rails": ["llm_token", "api_x402", "stablecoin", "card"],
  "budgets": {
    "team-research": 10.0,
    "team-support": 8.0,
    "default": 100.0
  },
  "max_amount": 5.0,
  "max_amount_by_rail": {
    "api_x402": 3.0,
    "stablecoin": 25.0,
    "card": 10.0
  },
  "warn_new_merchants": true,
  "gateway_tokens": ["dev-gateway-token"],
  "agents": {
    "research-bot": {
      "budgets": ["team-research"],
      "rails": ["llm_token", "api_x402", "stablecoin"],
      "max_amount": 3.0
    },
    "support-bot": {
      "budgets": ["team-support"],
      "rails": ["llm_token", "api_x402", "card"]
    }
  },
  "providers": {
    "openai": {
      "base_url": "https://api.openai.com",
      "api_key_env": "OPENAI_API_KEY",
      "rail": "llm_token",
      "provider": "openai",
      "merchant": "openai",
      "service_from_body": "model",
      "amount": 0.25,
      "budget": "team-research"
    }
  },
  "targets": {
    "scraper-demo": {
      "url": "https://example.com/scrape",
      "method": "POST",
      "rail": "api_x402",
      "provider": "x402",
      "merchant": "0xtool",
      "service": "/scrape",
      "amount": 2.5,
      "budget": "team-research",
      "headers": {
        "content-type": "application/json"
      }
    }
  }
}
