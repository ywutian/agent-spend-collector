      "enabled": false,
      "provider": "anthropic",
      "api_key_env": "ANTHROPIC_ADMIN_KEY"
    },
    "x402": {
      "enabled": true,
      "pay_to": "0xYourX402ReceivingAddress"
    },
    "usdc": {
      "enabled": true,
      "pay_to": "0xYourUSDCReceivingAddress"
    },
    "stripe": {
