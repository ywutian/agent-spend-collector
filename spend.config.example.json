{
  "db": "spend.db",
  "out_dir": "artifacts",
  "days": 7,
  "lookback_blocks": 2000,
  "budgets": {
    "team-research": 10.0,
    "team-support": 8.0,
    "team-ops": 25.0,
    "default": 100.0
  },
  "wallets": {
    "0xresearchwallet": {
      "agent_id": "research-bot",
      "budget_id": "team-research"
    },
    "0xsupportwallet": {
      "agent_id": "support-bot",
      "budget_id": "team-support"
    },
    "0xopswallet": {
      "agent_id": "ops-bot",
      "budget_id": "team-ops"
    }
  },
  "rails": {
    "llm": {
      "enabled": false,
      "provider": "anthropic",
      "api_key_env": "ANTHROPIC_ADMIN_KEY"
    },
    "openrouter": {
      "enabled": false,
      "provider": "openrouter",
      "api_key_env": "OPENROUTER_API_KEY",
      "generation_ids": []
    },
    "aws": {
      "enabled": false,
      "days": 7,
      "access_key_env": "AWS_ACCESS_KEY_ID",
      "secret_key_env": "AWS_SECRET_ACCESS_KEY",
      "session_token_env": "AWS_SESSION_TOKEN",
      "tag_agent": "agent_id",
      "tag_budget": "budget_id"
    },
    "gcp": {
      "enabled": false,
      "billing_export_file": "gcp-billing-export.ndjson",
      "label_agent": "agent_id",
      "label_budget": "budget_id"
    },
    "x402": {
      "enabled": true,
      "pay_to": "0xYourX402ReceivingAddress"
    },
    "usdc": {
      "enabled": true,
      "pay_to": "0xYourUSDCReceivingAddress"
    },
    "stripe": {
      "enabled": false,
      "api_key_env": "STRIPE_SECRET_KEY"
    }
  }
}
